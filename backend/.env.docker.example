APP_ENV=production
DEBUG=false
DATABASE_URL=postgresql://trading_scanner:trading_scanner_password@postgres:5432/trading_scanner
AUTO_CREATE_TABLES=false
MARKET_DATA_PROVIDER=yfinance
SCAN_DEFAULT_LOOKBACK_DAYS=300
MIN_AVG_VOLUME=500000
MAX_ATR_PERCENT=8
YFINANCE_CACHE_DIR=./.yf_cache
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
ALLOWED_ORIGINS=http://localhost:3000
