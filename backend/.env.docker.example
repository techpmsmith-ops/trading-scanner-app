APP_ENV=production
DEBUG=false
DATABASE_URL=postgresql://trading_scanner:trading_scanner_password@postgres:5432/trading_scanner
AUTO_CREATE_TABLES=false
MARKET_DATA_PROVIDER=yfinance
POLYGON_API_KEY=
MARKET_DATA_FALLBACK_PROVIDER=stooq
SCAN_DEFAULT_LOOKBACK_DAYS=300
MIN_AVG_VOLUME=500000
MAX_ATR_PERCENT=8
YFINANCE_CACHE_DIR=./.yf_cache
PHASE2_PREDICTION_SYMBOLS=INTC,NVDA,AMD,IONQ,NVTS
FOCUS_GROUP_SYMBOLS=INTC,NVDA,AMD,IONQ,NVTS,RVI,SMCI,RGTI,RKLB,MU
KRONOS_ENABLED=true
KRONOS_MODEL_NAME=NeoQuasar/Kronos-mini
KRONOS_TOKENIZER_NAME=NeoQuasar/Kronos-Tokenizer-2k
KRONOS_DEVICE=auto
KRONOS_LOOKBACK_BARS=120
KRONOS_FORECAST_BARS=5
KRONOS_MAX_SYMBOLS_PER_RUN=5
KRONOS_TIMEOUT_SECONDS=60
KRONOS_BULLISH_THRESHOLD_PCT=1.5
KRONOS_BEARISH_THRESHOLD_PCT=-1.5
KRONOS_HIGH_VOLATILITY_THRESHOLD_PCT=5.0
KRONOS_WEIGHT=0.20
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
ALLOWED_ORIGINS=http://localhost:3000
